{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": "./src",
    "ignoreDeprecations": "6.0"
  },
  "include": ["./src/**/*"]
}
